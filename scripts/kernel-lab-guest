#!/usr/bin/env bash
set -euo pipefail

action="${1:-status}"
repo_root="${2:-/opt/ecoroute-kernel-lab}"
gateway_url="http://127.0.0.1:8000"
gateway_key="ecoroute-demo-key"
agent_token="ecoroute-kernel-lab-token"
compose_files=(-f "$repo_root/compose.yaml" -f "$repo_root/infra/compose.kernel-lab.yaml")

require_repo() {
  if [[ ! -f "$repo_root/compose.yaml" || ! -f "$repo_root/pyproject.toml" ]]; then
    echo "EcoRoute repository not found at $repo_root" >&2
    exit 1
  fi
}

wait_for_url() {
  local url="$1"
  local attempts="${2:-90}"
  local count
  for ((count = 1; count <= attempts; count++)); do
    if curl --fail --silent --show-error "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done
  echo "Timed out waiting for $url" >&2
  return 1
}

agent_id() {
  tr -d '[:space:]' </var/lib/ecoroute-agent/agent-id
}

endpoint_id() {
  curl --fail --silent --show-error \
    -H "Authorization: Bearer $gateway_key" \
    "$gateway_url/api/v1/model-endpoints?limit=200" \
    | jq -r '.items[] | select(.name == "kernel-lab-cpu") | .id' \
    | head -n 1
}

env_value() {
  local name="$1"
  local fallback="$2"
  local value=""
  if [[ -f "$repo_root/.env" ]]; then
    value="$(sed -n "s/^${name}=//p" "$repo_root/.env" | tail -n 1 | tr -d '\r')"
    value="${value%\"}"
    value="${value#\"}"
  fi
  printf '%s' "${value:-$fallback}"
}

ollama_runner_pids() {
  # Ollama runner naming varies by release. Newer Linux builds launch the
  # loaded model as `llama-server`; older builds include `ollama` and
  # `runner` in the command line.
  ps -eo pid=,comm=,args= | awk '
    $2 == "llama-server" || ($2 == "ollama" && $0 ~ /runner/) { print $1 }
  ' | sort -un | paste -sd, -
}

prepare_ollama() {
  local model="$1"
  if ! command -v ollama >/dev/null 2>&1; then
    cat >&2 <<'EOF'
Ollama is not installed inside WSL.
Install it from the WSL terminal with:
  curl -fsSL https://ollama.com/install.sh | sh
Then rerun ./scripts/kernel-lab-wsl up.
EOF
    exit 1
  fi
  if ! systemctl cat ollama.service >/dev/null 2>&1; then
    echo "The Ollama systemd service is unavailable; reinstall Ollama inside WSL." >&2
    exit 1
  fi
  install -d -m 0755 /etc/systemd/system/ollama.service.d
  cat >/etc/systemd/system/ollama.service.d/ecoroute-kernel-lab.conf <<'EOF'
[Service]
Environment="OLLAMA_HOST=0.0.0.0:11434"
Environment="OLLAMA_KEEP_ALIVE=10m"
EOF
  systemctl daemon-reload
  systemctl enable --now ollama.service
  systemctl restart ollama.service
  wait_for_url "http://127.0.0.1:11434/api/tags" 45
  echo "Pulling real kernel-lab model $model (already-downloaded layers are reused)..."
  ollama pull "$model"
  curl --fail --silent --show-error \
    -H 'Content-Type: application/json' \
    --data "$(jq -n --arg model "$model" '{
      model: $model,
      messages: [{role: "user", content: "Reply with exactly: ready"}],
      stream: false,
      keep_alive: "10m",
      options: {temperature: 0, num_predict: 8}
    }')" \
    http://127.0.0.1:11434/api/chat \
    | jq -e '.message.content | type == "string" and length > 0' >/dev/null
  for _ in {1..30}; do
    [[ -n "$(ollama_runner_pids)" ]] && return
    sleep 1
  done
  echo "Ollama loaded the model but no runner PID was detected." >&2
  exit 1
}

install_docker_engine() {
  if command -v dockerd >/dev/null 2>&1 && \
    docker compose version >/dev/null 2>&1 && \
    systemctl cat docker.service >/dev/null 2>&1; then
    systemctl enable --now docker
    return
  fi

  echo "Installing Docker Engine and the Compose plugin from Docker's Ubuntu repository..."
  install -m 0755 -d /etc/apt/keyrings
  curl --fail --silent --show-error --location \
    https://download.docker.com/linux/ubuntu/gpg \
    -o /etc/apt/keyrings/docker.asc
  chmod a+r /etc/apt/keyrings/docker.asc

  # shellcheck disable=SC1091
  . /etc/os-release
  local ubuntu_codename="${UBUNTU_CODENAME:-${VERSION_CODENAME:-}}"
  if [[ "$ID" != "ubuntu" || -z "$ubuntu_codename" ]]; then
    echo "Automatic Docker installation currently supports Ubuntu only." >&2
    exit 1
  fi
  printf '%s\n' \
    "Types: deb" \
    "URIs: https://download.docker.com/linux/ubuntu" \
    "Suites: $ubuntu_codename" \
    "Components: stable" \
    "Architectures: $(dpkg --print-architecture)" \
    "Signed-By: /etc/apt/keyrings/docker.asc" \
    >/etc/apt/sources.list.d/docker.sources

  apt-get update
  if ! apt-get install --no-install-recommends -y \
    docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin; then
    echo "Docker installation failed. Remove conflicting distro Docker packages, then rerun." >&2
    echo "See https://docs.docker.com/engine/install/ubuntu/#uninstall-old-versions" >&2
    exit 1
  fi
  systemctl enable --now docker
}

verify_kernel_host() {
  if [[ "$(ps -p 1 -o comm= | tr -d '[:space:]')" != "systemd" ]]; then
    echo "systemd must be PID 1 for the real kernel lab." >&2
    exit 1
  fi
  if [[ ! -f /sys/fs/cgroup/cgroup.controllers ]] || \
    ! grep -qw cpu /sys/fs/cgroup/cgroup.controllers; then
    echo "The Linux host does not expose the cgroup v2 CPU controller." >&2
    exit 1
  fi
}

install_lab() {
  require_repo
  verify_kernel_host
  export DEBIAN_FRONTEND=noninteractive
  apt-get update
  apt-get install --no-install-recommends -y ca-certificates curl jq python3-venv
  install_docker_engine

  if [[ -e /opt/ecoroute-kernel-lab && ! -L /opt/ecoroute-kernel-lab ]]; then
    echo "/opt/ecoroute-kernel-lab exists and is not a symlink" >&2
    exit 1
  fi
  ln -sfn "$repo_root" /opt/ecoroute-kernel-lab
  if [[ ! -x /opt/ecoroute-kernel-lab-venv/bin/python ]]; then
    python3 -m venv /opt/ecoroute-kernel-lab-venv
  fi
  /opt/ecoroute-kernel-lab-venv/bin/pip install --disable-pip-version-check \
    httpx==0.28.1 psutil==7.2.2 SQLAlchemy==2.0.51 pgvector==0.5.0

  install -m 0644 \
    "$repo_root/services/kernel-lab/systemd/ecoroute-kernel-target.service" \
    /etc/systemd/system/ecoroute-kernel-target.service
  install -m 0644 \
    "$repo_root/services/kernel-lab/systemd/ecoroute-kernel-background.service" \
    /etc/systemd/system/ecoroute-kernel-background.service
  install -m 0644 \
    "$repo_root/services/kernel-lab/systemd/ecoroute-kernel-agent.service" \
    /etc/systemd/system/ecoroute-kernel-agent.service
  systemctl daemon-reload
}

start_lab() {
  install_lab
  if [[ ! -f "$repo_root/.env" ]]; then
    cp "$repo_root/.env.example" "$repo_root/.env"
  fi

  local backend
  local ollama_model
  backend="$(env_value ECOROUTE_KERNEL_LAB_BACKEND synthetic)"
  ollama_model="$(env_value ECOROUTE_KERNEL_LAB_OLLAMA_MODEL llama3.2:1b)"
  if [[ "$backend" == "ollama" ]]; then
    prepare_ollama "$ollama_model"
    systemctl stop ecoroute-kernel-target.service 2>/dev/null || true
  elif [[ "$backend" == "synthetic" ]]; then
    systemctl restart ecoroute-kernel-target.service
    wait_for_url "http://127.0.0.1:9100/healthz" 30
  else
    echo "ECOROUTE_KERNEL_LAB_BACKEND must be synthetic or ollama" >&2
    exit 1
  fi
  systemctl restart ecoroute-kernel-background.service
  for _ in {1..30}; do
    [[ -s /run/ecoroute-kernel-lab/background.pids ]] && break
    sleep 1
  done
  if [[ ! -s /run/ecoroute-kernel-lab/background.pids ]]; then
    echo "Background workload did not publish its PID list" >&2
    exit 1
  fi

  local inference_pid
  local background_pids
  local windows_host
  local lhm_url=""
  if [[ "$backend" == "ollama" ]]; then
    inference_pid="$(ollama_runner_pids)"
  else
    inference_pid="$(systemctl show --property MainPID --value ecoroute-kernel-target.service)"
  fi
  background_pids="$(tr -d '[:space:]' </run/ecoroute-kernel-lab/background.pids)"
  windows_host="$(ip route show default | awk 'NR == 1 {print $3}')"
  for candidate in "http://127.0.0.1:8085/data.json" "http://${windows_host}:8085/data.json"; do
    if curl --fail --silent --max-time 2 "$candidate" >/dev/null 2>&1; then
      lhm_url="$candidate"
      break
    fi
  done
  if [[ "$inference_pid" == "0" || -z "$inference_pid" || -z "$background_pids" ]]; then
    echo "Kernel workload PIDs are unavailable" >&2
    exit 1
  fi

  install -d -m 0700 /etc/ecoroute-kernel-lab /var/lib/ecoroute-agent
  umask 077
  {
    printf 'ECOROUTE_PUBLIC_URL=%s\n' "$gateway_url"
    printf 'ECOROUTE_AGENT_TOKEN=%s\n' "$agent_token"
    printf 'ECOROUTE_AGENT_STATE_DIR=/var/lib/ecoroute-agent\n'
    printf 'ECOROUTE_AGENT_APPROVED_CONTROLS=cgroups_v2,nice_ionice\n'
    printf 'ECOROUTE_INFERENCE_PIDS=%s\n' "$inference_pid"
    printf 'ECOROUTE_BACKGROUND_PIDS=%s\n' "$background_pids"
    printf 'ECOROUTE_CGROUP_ROOT=/sys/fs/cgroup/ecoroute.slice\n'
    printf 'ECOROUTE_ALLOW_HARD_CPU_QUOTA=true\n'
    if [[ -n "$lhm_url" ]]; then
      printf 'ECOROUTE_LHM_URL=%s\n' "$lhm_url"
      printf 'ECOROUTE_LHM_SAMPLE_SECONDS=0.5\n'
      printf 'ECOROUTE_BENCHMARK_GRID_ZONE=CA-ON\n'
    fi
  } >/etc/ecoroute-kernel-lab/agent.env
  if [[ -n "$lhm_url" ]]; then
    echo "Libre Hardware Monitor detected at $lhm_url; CPU package energy is enabled."
  else
    echo "Libre Hardware Monitor web server was not reachable; energy will remain unavailable."
  fi

  cd "$repo_root"
  docker compose "${compose_files[@]}" up --build -d --wait
  docker compose "${compose_files[@]}" stop agent-simulator >/dev/null 2>&1 || true
  wait_for_url "$gateway_url/readyz" 90

  systemctl restart ecoroute-kernel-agent.service
  for _ in {1..45}; do
    if [[ -s /var/lib/ecoroute-agent/agent-id ]]; then
      local current_agent_id
      current_agent_id="$(agent_id)"
      if curl --fail --silent --show-error \
        -H "Authorization: Bearer $gateway_key" \
        "$gateway_url/api/v1/agents/$current_agent_id" >/dev/null 2>&1; then
        break
      fi
    fi
    sleep 2
  done
  if [[ ! -s /var/lib/ecoroute-agent/agent-id ]]; then
    echo "Real node agent failed to register" >&2
    systemctl status --no-pager ecoroute-kernel-agent.service >&2 || true
    exit 1
  fi

  local current_agent_id
  local current_endpoint_id
  local endpoint_payload
  local endpoint_provider
  local endpoint_base_url
  local endpoint_model
  local endpoint_region
  local endpoint_grid_zone
  local processing_evidence
  local grid_attribution
  current_agent_id="$(agent_id)"
  current_endpoint_id="$(endpoint_id)"
  if [[ "$backend" == "ollama" ]]; then
    endpoint_provider="ollama"
    # LiteLLM's native Ollama adapter appends /api/generate itself. Supplying
    # /v1 here would produce the invalid path /v1/api/generate.
    endpoint_base_url="http://host.docker.internal:11434"
    endpoint_model="$ollama_model"
    endpoint_region="canada-ontario-local"
    endpoint_grid_zone="CA-ON"
    processing_evidence="self_hosted"
    grid_attribution="physical_grid"
  else
    endpoint_provider="openai_compatible"
    endpoint_base_url="http://host.docker.internal:9100/v1"
    endpoint_model="ecoroute-kernel-lab"
    endpoint_region="kernel-lab-local"
    endpoint_grid_zone="kernel-lab-local"
    processing_evidence="unknown"
    grid_attribution="unknown"
  fi
  endpoint_payload="$(jq -n \
    --arg agent "$current_agent_id" \
    --arg provider "$endpoint_provider" \
    --arg base_url "$endpoint_base_url" \
    --arg model "$endpoint_model" \
    --arg region "$endpoint_region" \
    --arg grid_zone "$endpoint_grid_zone" \
    --arg processing_evidence "$processing_evidence" \
    --arg grid_attribution "$grid_attribution" '{
    name: "kernel-lab-cpu",
    provider: $provider,
    baseUrl: $base_url,
    credentialRef: null,
    physicalModel: $model,
    region: $region,
    gridZone: $grid_zone,
    processingLocationEvidence: $processing_evidence,
    gridAttribution: $grid_attribution,
    qualityTier: "small",
    capabilities: ["text", "streaming"],
    contextWindowTokens: 4096,
    inputUsdPerMillionTokens: 0,
    outputUsdPerMillionTokens: 0,
    fixedRequestKwh: 0,
    inputKwhPer1kTokens: 0,
    outputKwhPer1kTokens: 0,
    energyEvidence: "estimated",
    latencyP50Ms: 100,
    latencyP95Ms: 500,
    selfHosted: true,
    nodeAgentId: $agent,
    baselineConcurrency: 8,
    concurrencyTarget: 8,
    enabled: true
  }')"
  if [[ -n "$current_endpoint_id" ]]; then
    curl --fail --silent --show-error \
      -X PATCH \
      -H "Authorization: Bearer $gateway_key" \
      -H 'Content-Type: application/json' \
      --data "$endpoint_payload" \
      "$gateway_url/api/v1/model-endpoints/$current_endpoint_id" >/dev/null
  else
    curl --fail --silent --show-error \
      -X POST \
      -H "Authorization: Bearer $gateway_key" \
      -H 'Content-Type: application/json' \
      --data "$endpoint_payload" \
      "$gateway_url/api/v1/model-endpoints" >/dev/null
  fi

  current_endpoint_id="$(endpoint_id)"
  curl --fail --silent --show-error \
    -X POST \
    -H "Authorization: Bearer $gateway_key" \
    -H 'Content-Type: application/json' \
    --data '{"confirm":true}' \
    "$gateway_url/api/v1/demo/hosting-routes/configure" >/dev/null
  curl --fail --silent --show-error \
    -X POST \
    -H "Authorization: Bearer $gateway_key" \
    -H 'Content-Type: application/json' \
    --data '{}' \
    "$gateway_url/api/v1/model-endpoints/$current_endpoint_id/test" \
    | jq '{status, provider, providerModel, latencyMs}'

  echo "EcoRoute real kernel lab is ready."
  echo "Agent: $current_agent_id"
  echo "Endpoint: $current_endpoint_id"
  echo "Backend: $backend"
  [[ "$backend" == "ollama" ]] && echo "Real LLM: $ollama_model"
  echo "Inference PID: $inference_pid"
  echo "Background PIDs: $background_pids"
}

run_demo() {
  require_repo
  local current_agent_id
  local current_endpoint_id
  local backend
  current_agent_id="$(agent_id)"
  current_endpoint_id="$(endpoint_id)"
  backend="$(env_value ECOROUTE_KERNEL_LAB_BACKEND synthetic)"
  if [[ -z "$current_endpoint_id" ]]; then
    echo "Kernel lab endpoint is not registered; run kernel-lab-up first" >&2
    exit 1
  fi

  curl --fail --silent --show-error \
    -X POST \
    -H "Authorization: Bearer $gateway_key" \
    -H 'Content-Type: application/json' \
    --data '{"profile":"observe"}' \
    "$gateway_url/api/v1/agents/$current_agent_id/desired-profile" >/dev/null

  local benchmark
  local benchmark_id
  benchmark="$(curl --fail --silent --show-error \
    -X POST \
    -H "Authorization: Bearer $gateway_key" \
    -H 'Content-Type: application/json' \
    -H "Idempotency-Key: kernel-lab-$(date +%s)" \
    --data "$(jq -n \
      --arg agent "$current_agent_id" \
      --arg endpoint "$current_endpoint_id" \
      --argjson concurrency "$([[ "$backend" == "ollama" ]] && echo 1 || echo 2)" \
      --argjson output_cap "$([[ "$backend" == "ollama" ]] && echo 32 || echo 64)" '{
      agentId: $agent,
      endpointId: $endpoint,
      profile: "eco",
      promptIds: ["returns", "shipping", "exchange", "delay"],
      warmupSeconds: 5,
      phaseSeconds: 30,
      cooldownSeconds: 5,
      concurrency: $concurrency,
      outputTokenCap: $output_cap
    }')" \
    "$gateway_url/api/v1/benchmarks")"
  benchmark_id="$(jq -r '.id' <<<"$benchmark")"
  echo "Benchmark $benchmark_id started (about 70 seconds)."

  local status=""
  local previous=""
  local result=""
  for _ in {1..120}; do
    result="$(curl --fail --silent --show-error \
      -H "Authorization: Bearer $gateway_key" \
      "$gateway_url/api/v1/benchmarks/$benchmark_id")"
    status="$(jq -r '.status' <<<"$result")"
    if [[ "$status" != "$previous" ]]; then
      echo "Benchmark status: $status"
      previous="$status"
    fi
    if [[ "$status" == "completed" || "$status" == "failed" || "$status" == "cancelled" ]]; then
      break
    fi
    sleep 2
  done
  if [[ "$status" != "completed" ]]; then
    echo "Benchmark ended with status $status" >&2
    jq . <<<"$result" >&2
    systemctl status --no-pager ecoroute-kernel-agent.service >&2 || true
    exit 1
  fi
  jq '{evidence, baselineMetrics, optimizedMetrics, comparison}' <<<"$result"
}

show_status() {
  systemctl is-active ecoroute-kernel-target.service || true
  systemctl is-active ecoroute-kernel-background.service || true
  systemctl is-active ecoroute-kernel-agent.service || true
  if [[ -s /var/lib/ecoroute-agent/agent-id ]]; then
    curl --fail --silent --show-error \
      -H "Authorization: Bearer $gateway_key" \
      "$gateway_url/api/v1/agents/$(agent_id)" \
      | jq '{id, hostname, status, activeProfile, capabilities, approvedControls, evidence}'
  fi
}

stop_lab() {
  systemctl stop ecoroute-kernel-agent.service 2>/dev/null || true
  systemctl stop ecoroute-kernel-background.service 2>/dev/null || true
  systemctl stop ecoroute-kernel-target.service 2>/dev/null || true
  if [[ -f "$repo_root/compose.yaml" ]]; then
    cd "$repo_root"
    docker compose "${compose_files[@]}" down || true
  fi
}

case "$action" in
  up) start_lab ;;
  demo) run_demo ;;
  status) show_status ;;
  down) stop_lab ;;
  *)
    echo "Usage: $0 {up|demo|status|down} [repository-root]" >&2
    exit 2
    ;;
esac
