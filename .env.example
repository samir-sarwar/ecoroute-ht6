# EcoRoute core
ECOROUTE_ENV=development
ECOROUTE_DEMO_MODE=true
ECOROUTE_GATEWAY_KEY=ecoroute-demo-key
ECOROUTE_AGENT_TOKEN=replace-me
ECOROUTE_DATABASE_URL=postgresql+asyncpg://ecoroute:ecoroute@postgres:5432/ecoroute
ECOROUTE_REDIS_URL=redis://redis:6379/0
ECOROUTE_PUBLIC_URL=http://localhost:8000
ECOROUTE_GATEWAY_INTERNAL_URL=http://gateway:8000
ECOROUTE_WEB_URL=http://localhost:3000
ECOROUTE_SUPPORT_DEMO_URL=http://localhost:3001
ECOROUTE_SUPPORT_DEMO_GATEWAY_KEY=ecoroute-demo-key

# Optional model and data services. Blank values disable live adapters.
FREESOLO_API_KEY=
FREESOLO_ORG=
FREESOLO_ROUTER_BASE_URL=
FREESOLO_ROUTER_MODEL_ID=
FREESOLO_SUPPORT_BASE_URL=
FREESOLO_SUPPORT_MODEL_ID=
GEMINI_API_KEY=
GEMINI_DATASET_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
ELECTRICITY_MAPS_API_KEY=
CARBON_AWARE_BASE_URL=http://carbon-aware:8080

# Optional local inference
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
VLLM_BASE_URL=

# Optional training/export
HF_TOKEN=
HF_ROUTER_REPOSITORY=
HF_SUPPORT_REPOSITORY=

# Telemetry and demo
ECOROUTE_EVENT_STREAM_MAXLEN=10000
ECOROUTE_TELEMETRY_RETENTION_DAYS=7
ECOROUTE_REQUEST_RETENTION_DAYS=30
ECOROUTE_SIMULATOR_SEED=42
ECOROUTE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ECOROUTE_USE_SENTENCE_TRANSFORMERS=true
ECOROUTE_CACHE_LOOKUP_KWH=0.000001
ECOROUTE_CACHE_MAX_ENTRIES=10000
ECOROUTE_CARBON_CACHE_SECONDS=300
ECOROUTE_PROVIDER_TIMEOUT_SECONDS=45
ECOROUTE_STREAM_TIMEOUT_SECONDS=120
ECOROUTE_MAX_REQUEST_BODY_BYTES=2000000
ECOROUTE_MAX_SSE_CONNECTIONS=100
ECOROUTE_ALLOWED_ENDPOINT_HOSTS=
ECOROUTE_ALLOWED_CREDENTIAL_ENVS=FREESOLO_API_KEY,GEMINI_API_KEY,OPENAI_API_KEY,OLLAMA_API_KEY,VLLM_API_KEY
ECOROUTE_FAKE_PROVIDER_DELAY_MS=35
ECOROUTE_AGENT_APPROVED_CONTROLS=gateway_concurrency
ECOROUTE_AGENT_STATE_DIR=/var/lib/ecoroute-agent

# Real Linux agent only. Controls remain disabled until listed above and detected.
ECOROUTE_GATEWAY_BASELINE_CONCURRENCY=16
ECOROUTE_INFERENCE_PIDS=
ECOROUTE_BACKGROUND_PIDS=
ECOROUTE_CGROUP_ROOT=/sys/fs/cgroup/ecoroute.slice
ECOROUTE_ALLOW_HARD_CPU_QUOTA=false
ECOROUTE_GPU_MAX_TEMPERATURE_C=85
ECOROUTE_SCHED_EXT_BINARY=
ECOROUTE_SCHED_EXT_ARGS=[]
ECOROUTE_SCHED_EXT_SHA256=
ECOROUTE_NAPI_YNL_HELPER=
ECOROUTE_NAPI_INTERFACES=
ECOROUTE_NAPI_VALUES={}
