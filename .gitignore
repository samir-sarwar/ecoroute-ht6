# --- secrets (NEVER commit) ---
.env
.env.*
!.env.example

# --- large / regenerable data ---
# RouterBench raw is 1.2 GB and downloadable from HuggingFace; regenerate the
# jsonl datasets from it with scripts/build_router_dataset.py. The generated
# training jsonl files ARE committed (small, reproducible training inputs).
*.pkl
data/routerbench/*.pkl

