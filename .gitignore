# --- secrets (NEVER commit) ---
.env
.env.*
!.env.example

# --- large / regenerable data ---
# RouterBench raw is 1.2 GB and downloadable from HuggingFace; regenerate the
# jsonl datasets from it with scripts/build_router_dataset.py. The generated
# training jsonl files ARE committed (small, reproducible training inputs).
*.pkl
data/routerbench/*.pkl
training/**/configs/*.rendered.toml
training/**/dataset/generated/

# --- python ---
__pycache__/
*.pyc
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
coverage.xml
.coverage

# --- node ---
node_modules/
.next/
playwright-report/
test-results/
dist/
build/

# --- os / editor noise ---
.DS_Store
Thumbs.db
*.log

# --- misc ---
agent-state/

