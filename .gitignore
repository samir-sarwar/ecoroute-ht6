__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- node ---
node_modules/
dist/
build/

# --- os / editor noise ---
.DS_Store
Thumbs.db
*.log
